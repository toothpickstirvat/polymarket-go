# Polymarket CLOB Client Configuration
# Copy this file to .env and fill in your values

# Private Key (without 0x prefix or with it)
PRIVATE_KEY=your_private_key_here

# Test Configuration
# Event slug for testing (e.g., "will-bitcoin-hit-100k-in-2024")
TEST_EVENT_SLUG=

# Market ID for testing (numeric ID, e.g., "239826")
TEST_MARKET_ID=

# Condition ID for testing (market condition ID, used by market_trade example)
TEST_CONDITION_ID=

# Token ID for testing (replace with actual token ID from a live market)
TEST_TOKEN_ID=21742633143463906290569050155826241533067272736897614950488156847949938836455
